# ──────────────────────────────────────────────────────────────────────────
# SocialFlow — environment variables
# Copy to .env.local (app) and set the same on the worker host.
# ──────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database — Neon (Postgres). Use the pooled connection string.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Queue broker — Upstash Redis (use the rediss:// string).
# BullMQ requires maxRetriesPerRequest=null (set in code).
REDIS_URL=rediss://default:password@host:6379

# Token encryption (Goal 2) — 32+ char secret for social OAuth tokens at rest.
ENCRYPTION_KEY=

# LangSmith observability (Goal 4)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=social-saas
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# CI only: set to build without real secrets.
# SKIP_ENV_VALIDATION=true
