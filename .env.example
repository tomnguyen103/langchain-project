# ──────────────────────────────────────────────────────────────────────────
# SocialFlow — environment variables
# Copy to .env.local (app) and set the same on the worker host.
# ──────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database — Neon (Postgres). Use the pooled connection string.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
# DB driver: "http" (default; serverless app), "pool" (pooled WebSocket
# connection), or "node-postgres" for local/CI integration tests. The worker
# entry defaults itself to "pool"; leave unset for the app. Set explicitly only
# to override (e.g. DB_DRIVER=http on the worker host).
# DB_DRIVER=pool

# Queue broker — Upstash Redis (use the rediss:// string).
# BullMQ requires maxRetriesPerRequest=null (set in code).
REDIS_URL=rediss://default:password@host:6379

# Auth — Clerk (clerk.com → your app → API Keys).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Token encryption — 32+ char secret for social OAuth tokens at rest.
ENCRYPTION_KEY=

# Media storage — ImageKit (imagekit.io → Developer → API Keys).
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=public_xxx
IMAGEKIT_PRIVATE_KEY=private_xxx
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# Meta (Facebook + Instagram) — developers.facebook.com app.
# Add {APP_URL}/api/oauth/meta/callback as a valid OAuth redirect URI.
META_APP_ID=
META_APP_SECRET=
# Verify token for the Meta comments webhook handshake — optional.
META_WEBHOOK_VERIFY_TOKEN=

# LinkedIn (optional) — linkedin.com/developers app with the "Share on LinkedIn"
# + "Sign In with LinkedIn using OpenID Connect" products.
# Add {APP_URL}/api/oauth/linkedin/callback as an authorized redirect URL.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# TikTok (optional) — developers.tiktok.com app with the Content Posting API.
# Add {APP_URL}/api/oauth/tiktok/callback as a redirect URI.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# X / Twitter (optional) — developer.x.com app with OAuth2 + v2 API access.
# Add {APP_URL}/api/oauth/x/callback as a callback URL.
X_CLIENT_ID=
X_CLIENT_SECRET=

# Pinterest (optional) — developers.pinterest.com app with v5 API access.
# Add {APP_URL}/api/oauth/pinterest/callback as a redirect URI.
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# YouTube (optional) — Google Cloud console app with the YouTube Data API v3
# enabled. Add {APP_URL}/api/oauth/youtube/callback as an authorized redirect URI.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# LLM providers — Gemini is the default (aistudio.google.com). Others optional.
LLM_PROVIDER=gemini
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Web research (optional) — tavily.com API key. Research falls back to LLM
# knowledge if unset.
TAVILY_API_KEY=

# LangSmith observability (optional) — when set, traces every agent LLM call.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=social-saas
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# Workspace + project ids (UUIDs) for building LangSmith run deep links.
LANGSMITH_ORG_ID=
LANGSMITH_PROJECT_ID=

# Health checks — optional bearer token so an uptime monitor can scrape
# /api/health/queues (queue depths). When unset, that endpoint requires a
# signed-in session instead. /api/health (liveness) is always public.
HEALTH_CHECK_TOKEN=

# MCP, inward (optional) — agents can call tools on a configured MCP server.
MCP_SERVER_URL=
MCP_SERVER_TOKEN=

# A2A, outward (optional) — expose the content agent over Agent2Agent.
# Disabled unless A2A_ENABLED="true".
A2A_ENABLED=
# Single-tenant mode: A2A_TOKEN is the bearer secret callers present;
# A2A_TENANT_ID is the Clerk user id the token acts as.
A2A_TOKEN=
A2A_TENANT_ID=
# Multi-tenant mode (overrides A2A_TOKEN/A2A_TENANT_ID when set): JSON object
# {"<bearer-token>": "<clerk-user-id>"} mapping each token to its own tenant.
A2A_TENANT_TOKENS=

# CI only: set to build without real secrets.
# SKIP_ENV_VALIDATION=true
